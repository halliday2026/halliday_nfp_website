---
import { Image } from 'astro:assets';
import hLogoIcon from '../assets/H_Logo.svg';

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/data-work', label: 'Data Work' },
  { href: '/managed-websites', label: 'Managed Websites' },
  { href: '/cost-calculator', label: 'Cost Calculator' },
  { href: '/case-studies', label: 'Proof' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-[var(--color-charcoal)] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/" aria-label="Halliday home" class="inline-flex items-center gap-2.5 mb-4">
          <Image src={hLogoIcon} alt="" width={28} height={32} class="h-7 w-auto brightness-0 invert" />
          <span class="font-heading font-bold text-lg tracking-wide text-white">HALLIDAY</span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed">
          A professional web presence and the custom data tools to raise more, report faster, and prove your impact.
        </p>
        <p class="text-white/50 text-xs leading-relaxed mt-4">
          And for the consultants, coaches, and grant writers in their orbit — the same done-for-you web presence keeps your professional presence running, too.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-white/50 mb-4">
          Quick Links
        </h3>
        <ul class="space-y-2" role="list">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/70 hover:text-white text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact CTA -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-white/50 mb-4">
          Get in Touch
        </h3>
        <p class="text-white/70 text-sm leading-relaxed mb-1">
          Huntington Beach, CA
        </p>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          Ready to see what's possible?<br/>Let's talk.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-[var(--color-navy)] hover:bg-[var(--color-navy-dark)] text-white px-5 py-2.5 rounded-full text-sm font-semibold transition-colors"
        >
          Book a discovery call
        </a>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-white/40">
      <p>&copy; 2026 Halliday. All rights reserved.</p>
      <p>hallidayinc.com</p>
    </div>
  </div>
</footer>
