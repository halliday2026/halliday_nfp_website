---
import BaseLayout from '../layouts/BaseLayout.astro';

const whatYouGet = [
  'A professional, modern website built for your organization',
  'Hosting, security, and maintenance — handled',
  'Content updates when you need them',
  'A real person who knows your site, not a support ticket queue',
  'Always current, always working — checked, not assumed',
];
---

<BaseLayout
  title="Managed Websites"
  description="A professional website we build and keep running for you. A real person makes sure it's always current and working, so you never have to think about it again."
>
  <!-- ======================== HEADER ======================== -->
  <section class="py-20 lg:py-28 bg-[var(--color-charcoal)]" data-animate>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-white/60 font-semibold text-sm uppercase tracking-widest mb-6">
        Managed Websites
      </p>
      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6"
        style="font-family: var(--font-heading);"
      >
        A professional web presence — handled for you.
      </h1>
      <p class="text-white/70 text-lg leading-relaxed max-w-2xl">
        One less thing to think about. We build it, we run it, and we make sure it never breaks — so you can focus on your mission.
      </p>
    </div>
  </section>

  <!-- ======================== WHAT YOU GET ======================== -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12" data-animate>
        <h2
          class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
          style="font-family: var(--font-heading);"
        >
          What you get
        </h2>
        <p class="text-[var(--color-muted)] text-lg leading-relaxed">
          A professional website we build and keep running for you. A real person makes sure it's always current and working, so you never have to think about it again.
        </p>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4" role="list">
        {whatYouGet.map((item, i) => (
          <li
            class="flex items-start gap-3 p-5 rounded-xl bg-[var(--color-stone)] border border-[var(--color-border)]"
            data-animate
            data-animate-delay={String(i * 100)}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[var(--color-navy)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-[var(--color-body)] text-base">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ======================== WHO IT'S FOR ======================== -->
  <section class="py-20 lg:py-28 bg-[var(--color-stone)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2
        class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-6"
        style="font-family: var(--font-heading);"
      >
        Who it's for
      </h2>
      <p class="text-[var(--color-body)] text-lg leading-relaxed mb-6">
        Any nonprofit that needs a credible web presence — regardless of size or budget.
      </p>
      <p class="text-[var(--color-muted)] text-base leading-relaxed">
        And for the consultants, coaches, and grant writers in their orbit, the same done-for-you web presence keeps their professional presence running — so they can focus on their clients.
      </p>
    </div>
  </section>

  <!-- ======================== GROW-INTO LINE ======================== -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8" data-animate>
      <div class="flex flex-col sm:flex-row sm:items-center gap-5 p-7 rounded-2xl bg-[var(--color-navy-tint)] border border-[var(--color-navy)]/15">
        <p class="text-[var(--color-body)] text-base leading-relaxed flex-1">
          And when you're ready, this is the door into the data tools — turning what you already have into decisions you can act on.
        </p>
        <a
          href="/data-work"
          class="inline-flex items-center justify-center gap-2 text-[var(--color-navy)] font-semibold hover:gap-3 transition-all text-sm whitespace-nowrap"
        >
          See Data Work
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ======================== PRICING ======================== -->
  <section class="py-20 lg:py-28 bg-[var(--color-stone)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2
        class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-8"
        style="font-family: var(--font-heading);"
      >
        Pricing
      </h2>
      <div class="bg-white rounded-2xl border border-[var(--color-border)] p-10 lg:p-12 inline-block">
        <p class="text-5xl font-bold text-[var(--color-ink)] mb-2" style="font-family: var(--font-heading);">
          $75<span class="text-xl font-medium text-[var(--color-muted)]">/month</span>
        </p>
        <p class="text-[var(--color-muted)] text-base">
          Covers hosting, maintenance, and ongoing updates — handled by a real person.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================== CTA ======================== -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2
        class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
        style="font-family: var(--font-heading);"
      >
        Ready for a website you don't have to think about?
      </h2>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-[var(--color-navy)] hover:bg-[var(--color-navy-dark)] text-white px-8 py-4 rounded-full text-lg font-semibold transition-colors"
      >
        Get started
      </a>
    </div>
  </section>
</BaseLayout>
