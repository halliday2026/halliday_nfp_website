---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { heroConfig } from '../data/hero';
import { pillars } from '../data/pillars';
import { beforeAfter } from '../data/before-after';
// Hero photo: "Focused man working on laptop at desk" by Michael Burrows, via Pexels
// (Pexels License — free for commercial use, no attribution required).
// https://www.pexels.com/photo/focused-ethnic-man-working-on-laptop-at-desk-7128964/
import heroPhoto from '../assets/hero-operator.jpg';

const selfIdentify = [
  'Data living in 3+ places',
  'A recent grant win — new money, new reporting obligations',
  'No in-house data person',
  'Board decks assembled by hand',
];

const pillarIcons: Record<string, string> = {
  'web-presence': `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zM3.6 9h16.8M3.6 15h16.8M12 3a14.5 14.5 0 010 18 14.5 14.5 0 010-18z" /></svg>`,
  'raise-more': `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
  'report-faster': `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
  'prove-impact': `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
};
---

<BaseLayout
  title="Home"
  description="Halliday builds nonprofits a professional web presence — and the custom data tools to raise more, report faster, and prove their impact."
>
  <!-- ======================== HERO ======================== -->
  <section class="relative overflow-hidden min-h-[92vh] lg:min-h-screen flex items-center">
    <div class="absolute inset-0" aria-hidden="true">
      <Image
        src={heroPhoto}
        alt=""
        class="w-full h-full object-cover grayscale contrast-[1.05] brightness-[0.92]"
        style="object-position: 68% center;"
        widths={[640, 1024, 1600, 2400]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        aria-hidden="true"
      />
      <!-- Duotone tint: recolors the desaturated photo into the brand palette -->
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-charcoal)] to-[var(--color-navy-dark)] mix-blend-color opacity-80"></div>
      <!-- Legibility scrim: directional darken, strongest where the headline sits -->
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-charcoal)]/95 via-[var(--color-charcoal)]/75 to-[var(--color-charcoal)]/25"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="max-w-3xl">
        <p class="text-white/60 font-semibold text-sm uppercase tracking-widest mb-6">
          {heroConfig.eyebrow}
        </p>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-8"
          style="font-family: var(--font-heading);"
        >
          {heroConfig.headline}
        </h1>
        <p class="text-white/75 text-xl leading-relaxed mb-10 max-w-2xl">
          {heroConfig.subhead}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={heroConfig.primaryCta.href}
            class="inline-flex items-center justify-center gap-2 bg-[var(--color-navy)] hover:bg-[var(--color-navy-dark)] text-white px-7 py-4 rounded-full text-base font-semibold transition-colors"
          >
            {heroConfig.primaryCta.label}
          </a>
          <a
            href={heroConfig.secondaryCta.href}
            class="inline-flex items-center justify-center gap-2 border-2 border-white/40 hover:border-white text-white px-7 py-4 rounded-full text-base font-semibold transition-colors hover:bg-white/10"
          >
            {heroConfig.secondaryCta.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================== WHO THIS IS FOR ======================== -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2
        class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
        style="font-family: var(--font-heading);"
      >
        Does this sound like you?
      </h2>
      <p class="text-[var(--color-muted)] text-lg mb-12">
        Halliday works with nonprofits in the messy middle — big enough to run several disconnected systems, too lean to afford a dedicated data hire.
      </p>

      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left" role="list">
        {selfIdentify.map((signal, i) => (
          <li
            class="flex items-start gap-3 p-5 rounded-xl bg-[var(--color-stone)] border border-[var(--color-border)]"
            data-animate
            data-animate-delay={String(i * 100)}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[var(--color-navy)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-[var(--color-body)] text-base">{signal}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ======================== BEFORE / AFTER (condensed) ======================== -->
  <section class="py-20 lg:py-28 bg-[var(--color-stone)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14" data-animate>
        <h2
          class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
          style="font-family: var(--font-heading);"
        >
          From scattered to clear
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-8 border border-[var(--color-border)]" data-animate>
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-5">Before</p>
          <ul class="space-y-3">
            {beforeAfter.before.slice(0, 3).map((line) => (
              <li class="flex items-start gap-3 text-[var(--color-body)] text-base leading-relaxed">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-muted)] flex-shrink-0 mt-2.5" />
                {line}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-[var(--color-navy)]/20" data-animate data-animate-delay="100">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-navy)] mb-5">After</p>
          <ul class="space-y-3">
            {beforeAfter.after.slice(0, 3).map((line) => (
              <li class="flex items-start gap-3 text-[var(--color-body)] text-base leading-relaxed">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-navy)] flex-shrink-0 mt-2.5" />
                {line}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================== PILLARS ======================== -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14" data-animate>
        <h2
          class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
          style="font-family: var(--font-heading);"
        >
          Start with a website. Grow into the data.
        </h2>
        <p class="text-[var(--color-muted)] text-lg">
          One front door, three outcomes once you're ready to go further.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {pillars.map((pillar, i) => (
          <div
            class="p-7 rounded-2xl bg-[var(--color-stone)] border border-[var(--color-border)]"
            data-animate
            data-animate-delay={String(i * 100)}
          >
            <div class="w-12 h-12 rounded-xl bg-[var(--color-navy)]/10 flex items-center justify-center text-[var(--color-navy)] mb-5" set:html={pillarIcons[pillar.key]} />
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-navy)] mb-2">{pillar.eyebrow}</p>
            <h3
              class="text-lg font-bold text-[var(--color-ink)] mb-3"
              style="font-family: var(--font-heading);"
            >
              {pillar.title}
            </h3>
            <p class="text-[var(--color-muted)] text-sm leading-relaxed">{pillar.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== CALCULATOR TEASER ======================== -->
  <section class="py-20 lg:py-28 bg-[var(--color-charcoal)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2
        class="text-3xl sm:text-4xl font-bold text-white mb-5"
        style="font-family: var(--font-heading);"
      >
        What is scattered data costing your nonprofit?
      </h2>
      <p class="text-white/70 text-lg mb-10">
        A 60-second estimate of the hours and dollars lost each year to fragmented data and manual reporting — no email required to see it.
      </p>
      <a
        href="/cost-calculator"
        class="inline-flex items-center gap-2 bg-[var(--color-navy)] hover:bg-[var(--color-navy-dark)] text-white px-7 py-4 rounded-full text-base font-semibold transition-colors"
      >
        Calculate your cost
      </a>
    </div>
  </section>

  <!-- ======================== PROOF TEASER ======================== -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14" data-animate>
        <h2
          class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
          style="font-family: var(--font-heading);"
        >
          Results That Speak for Themselves
        </h2>
        <p class="text-[var(--color-muted)] text-lg">
          Real work with real nonprofits — and the insights that changed how they operate.
        </p>
      </div>

      <div
        class="bg-[var(--color-stone)] rounded-2xl border border-[var(--color-border)] p-8 lg:p-10"
        data-animate
      >
        <span class="inline-block bg-[var(--color-navy)]/10 text-[var(--color-navy)] text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-4">
          Case Study
        </span>
        <p class="text-[var(--color-muted)] text-sm font-medium mb-3">Southern California Habitat Conservation Nonprofit</p>
        <p class="text-[var(--color-body)] text-base leading-relaxed mb-6">
          A conservation nonprofit had five years of donor data but no structured way to analyze it. We uncovered critical insights about donor acquisition, retention trends, and early warning signs for donor attrition — giving leadership a clear, data-driven picture of their donor base health for the first time.
        </p>
        <a
          href="/case-studies/conservation-nonprofit"
          class="inline-flex items-center gap-2 text-[var(--color-navy)] font-semibold hover:gap-3 transition-all text-sm"
        >
          Read the full case study
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ======================== FINAL CTA ======================== -->
  <section class="py-20 lg:py-28 bg-[var(--color-stone)]">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2
        class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-5"
        style="font-family: var(--font-heading);"
      >
        Ready to see what's possible?
      </h2>
      <p class="text-[var(--color-muted)] text-lg mb-8">
        Tell us about your organization — no pitch, just a useful conversation about where you are and what's next.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-[var(--color-navy)] hover:bg-[var(--color-navy-dark)] text-white px-8 py-4 rounded-full text-lg font-semibold transition-colors"
      >
        Book a discovery call
      </a>
    </div>
  </section>
</BaseLayout>
